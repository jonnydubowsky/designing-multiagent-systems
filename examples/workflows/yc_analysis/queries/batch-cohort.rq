# YC Batch Cohort Analysis — Performance by YC batch year
# Schedule: Weekly (unique to AI agent vertical)
# Intent: Track how different YC batches perform in the AI agent space.
# Recent batches (W24, S24) vs older ones — who has staying power?

PREFIX asbpi: <https://shurai.com/ontology/ai-agent-sbpi#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:   <http://www.w3.org/2001/XMLSchema#>

SELECT ?batchLabel ?companyCount ?avgComposite ?avgMC ?avgMT ?avgPE ?avgAD ?avgCD
       ?agentCount ?agentPct
WHERE {
    {
        SELECT ?batchLabel
               (COUNT(DISTINCT ?c) AS ?companyCount)
               (AVG(?composite) AS ?avgComposite)
               (AVG(?mc) AS ?avgMC)
               (AVG(?mt) AS ?avgMT)
               (AVG(?pe) AS ?avgPE)
               (AVG(?ad) AS ?avgAD)
               (AVG(?cd) AS ?avgCD)
               (SUM(IF(?isAgent, 1, 0)) AS ?agentCount)
        WHERE {
            ?sr a asbpi:ScoreRecord ;
                asbpi:forCompany ?c ;
                asbpi:compositeScore ?composite ;
                asbpi:hasDimensionScore ?ds_mc ;
                asbpi:hasDimensionScore ?ds_mt ;
                asbpi:hasDimensionScore ?ds_pe ;
                asbpi:hasDimensionScore ?ds_ad ;
                asbpi:hasDimensionScore ?ds_cd .

            ?c asbpi:fromBatch ?batch ;
               asbpi:isAgent ?isAgent .
            ?batch asbpi:batchLabel ?batchLabel .

            ?ds_mc asbpi:forDimension asbpi:ModelCapability ; asbpi:dimensionValue ?mc .
            ?ds_mt asbpi:forDimension asbpi:MarketTraction ; asbpi:dimensionValue ?mt .
            ?ds_pe asbpi:forDimension asbpi:PlatformEcosystem ; asbpi:dimensionValue ?pe .
            ?ds_ad asbpi:forDimension asbpi:AutonomyDepth ; asbpi:dimensionValue ?ad .
            ?ds_cd asbpi:forDimension asbpi:CapitalDefensibility ; asbpi:dimensionValue ?cd .

            ?sr asbpi:forWeek ?w .
            FILTER NOT EXISTS { ?w2 asbpi:previousWeek ?w . }
        }
        GROUP BY ?batchLabel
    }
    BIND(?agentCount / ?companyCount * 100 AS ?agentPct)
}
ORDER BY DESC(?avgComposite)
